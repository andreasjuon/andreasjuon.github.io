# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx
*.crt
*.jsonl

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# local env files
.env*.local
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# internal / agent documentation — not for public repo
README.md
AGENTS.md
CLAUDE.md
CONTEXT.md
SKILL.md
docs/
.claude/
.cursor/
.agents/
prompt.docx

# local migration/review artifacts
humanizer_review.html
/scripts/wp-export/
/_private_assets/

# accidental Finder/back-up copies
/content/* copy/

# local authoring drafts
/content/**/_TEMPLATE.mdx
/content/**/old/

# source assets should stay outside public/ so they cannot be deployed
/public/**/*.psd
/public/images/**/*.pdf

# original raster images — keep on disk for reference but ship only the converted .webp versions
/public/images/**/*.jpg
/public/images/**/*.jpeg
/public/images/**/*.png
/public/images/**/*.bmp
/public/images/**/*.tiff
/public/images/**/*.tif
